# Copy this file to .env.local and fill in your values

# ─── Sitecore Experience Edge (for Download Layout JSON) ─────────────────────
# Your XM Cloud Experience Edge context ID — kept server-side only for security.
# Find it in XM Cloud Portal under your environment's API access settings.
SITECORE_EDGE_CONTEXT_ID=your-context-id

# Default site name — used as fallback when siteInfo is not available in context.
# NEXT_PUBLIC_DEFAULT_SITE_NAME=your-site-name

# ─── Site URL (for Download Page HTML) ───────────────────────────────────────
# Public base URL of the Sitecore delivery/preview site.
# Used by the "Download Page HTML" button in the Content Intelligence panel.
# e.g. https://my-site.vercel.app  or  https://preview-my-site.xmcloud.sitecore.cloud
# NEXT_PUBLIC_SITE_URL=https://your-site-url

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Set to "anthropic" or "openai". If omitted, auto-detected from whichever
# API key is present (Anthropic is preferred when both keys are set).
# AI_PROVIDER=anthropic

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Model to use (defaults to claude-sonnet-4-6 if not set)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── OpenAI (ChatGPT) ─────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# Model to use (defaults to gpt-4o if not set)
# OPENAI_MODEL=gpt-4o
